{
  "name": "@swingops/api",
  "version": "0.1.0",
  "private": true,
  "description": "Fastify API for SwingOps AI workflow, intake, review, model-call, and tool-call operations.",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "mcp:dev": "tsx src/mcp/server.ts",
    "mcp:start": "node dist/mcp/server.js"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^6.2.1",
    "@swingops/shared": "workspace:*",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "pino": "^9.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
