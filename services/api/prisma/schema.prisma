generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GolfClubCategory {
  DRIVER
  FAIRWAY_WOOD
  HYBRID
  IRON_SET
  WEDGE
  PUTTER
}

enum ShaftFlex {
  LADIES
  SENIOR
  REGULAR
  STIFF
  X_STIFF
}

enum Dexterity {
  RIGHT
  LEFT
}

enum ClubCondition {
  NEW
  EXCELLENT
  VERY_GOOD
  GOOD
  FAIR
}

enum IntakeBatchStatus {
  DRAFT
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  NEEDS_REVIEW
}

enum IntakeItemStatus {
  PENDING
  PROCESSING
  STRUCTURED
  NEEDS_REVIEW
  FAILED
}

/// Legacy batch-level source metadata for IntakeBatch records.
/// Current guided intake source types are enforced in the workflow/API layer:
/// FREE_TEXT, POORLY_FORMED_CSV, EMAIL, LOG.
enum IntakeSourceType {
  FREEFORM_NOTES
  BAD_CSV
  EMAIL
  PDF_TEXT
  MANUAL_ENTRY
}

enum WorkflowRunStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  NEEDS_REVIEW
  CANCELLED
}

enum WorkflowStepStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
  RETRYING
}

enum WorkflowStepType {
  PARSE_INPUT
  NORMALIZE_DATA
  EXTRACT_GOLF_CLUB_FIELDS
  VALIDATE_STRUCTURED_OUTPUT
  CREATE_REVIEW_ITEM
  PERSIST_GOLF_CLUB
}

enum ToolCallStatus {
  STARTED
  SUCCEEDED
  FAILED
  RETRIED
}

enum ModelCallStatus {
  STARTED
  SUCCEEDED
  FAILED
  RETRIED
  SKIPPED
}

enum ModelCallAttemptStatus {
  SUCCESS
  FAILED
  SKIPPED
  TIMEOUT
  UNHEALTHY
  DISABLED
  RATE_LIMITED
}

enum ModelProviderName {
  MOCK
  OPENAI
  ANTHROPIC
  AZURE_OPENAI
  OLLAMA
}

enum ReviewQueueStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  DISMISSED
}

enum ReviewReason {
  MISSING_REQUIRED_FIELDS
  LOW_CONFIDENCE
  VALIDATION_FAILED
  AMBIGUOUS_INPUT
  POSSIBLE_DUPLICATE
  MANUAL_REVIEW_REQUESTED
}

enum KnowledgeSourceType {
  FREE_TEXT
  CSV
  PDF_TEXT
  POLICY_NOTE
}

enum KnowledgeChunkType {
  CLUB_REFERENCE
  TRADE_IN_POLICY
  CONDITION_GUIDE
  BRAND_ALIAS
  SHAFT_FLEX_GUIDE
}

enum KnowledgeIngestionRunStatus {
  STARTED
  SUCCEEDED
  FAILED
}

enum AiReadyIntakeRecordStatus {
  READY_FOR_REVIEW
  READY_FOR_RAG
  NEEDS_REVIEW
}

model IntakeBatch {
  id          String            @id @default(cuid())
  name        String
  description String?
  sourceType  IntakeSourceType  @map("source_type")
  status      IntakeBatchStatus @default(DRAFT)
  itemCount   Int               @default(0) @map("item_count")

  items                IntakeItem[]
  workflowRuns         WorkflowRun[]
  aiReadyIntakeRecords AiReadyIntakeRecord[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([sourceType])
  @@map("intake_batches")
}

model IntakeItem {
  id              String           @id @default(cuid())
  intakeBatchId   String           @map("intake_batch_id")
  rawText         String           @map("raw_text")
  sourceRowNumber Int?             @map("source_row_number")
  status          IntakeItemStatus @default(PENDING)

  intakeBatch               IntakeBatch                @relation(fields: [intakeBatchId], references: [id], onDelete: Cascade)
  golfClubs                 GolfClub[]
  workflowRuns              WorkflowRun[]
  reviewQueueItems          ReviewQueueItem[]
  reviewedTradeInRecords    ReviewedTradeInRecord[]
  humanReviewLearningEvents HumanReviewLearningEvent[]
  aiReadyIntakeRecords      AiReadyIntakeRecord[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([intakeBatchId])
  @@index([status])
  @@map("intake_items")
}

model GolfClub {
  id           String  @id @default(cuid())
  intakeItemId String? @map("intake_item_id")

  brand    String
  model    String
  category GolfClubCategory

  loft       String?
  shaftBrand String?    @map("shaft_brand")
  shaftFlex  ShaftFlex? @map("shaft_flex")
  dexterity  Dexterity?

  condition ClubCondition

  gripCondition String? @map("grip_condition")
  length        String?
  notes         String?

  confidenceScore Float    @map("confidence_score")
  missingFields   String[] @default([]) @map("missing_fields")

  intakeItem       IntakeItem?       @relation(fields: [intakeItemId], references: [id], onDelete: SetNull)
  reviewQueueItems ReviewQueueItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([intakeItemId])
  @@index([brand])
  @@index([category])
  @@index([condition])
  @@map("golf_clubs")
}

model WorkflowRun {
  id            String            @id @default(cuid())
  intakeBatchId String?           @map("intake_batch_id")
  intakeItemId  String?           @map("intake_item_id")
  workflowName  String            @map("workflow_name")
  status        WorkflowRunStatus @default(QUEUED)

  startedAt    DateTime? @map("started_at")
  completedAt  DateTime? @map("completed_at")
  errorMessage String?   @map("error_message")

  intakeBatch          IntakeBatch?          @relation(fields: [intakeBatchId], references: [id], onDelete: SetNull)
  intakeItem           IntakeItem?           @relation(fields: [intakeItemId], references: [id], onDelete: SetNull)
  steps                WorkflowStep[]
  toolCallLogs         ToolCallLog[]
  modelCallLogs        ModelCallLog[]
  reviewQueueItems     ReviewQueueItem[]
  aiReadyIntakeRecords AiReadyIntakeRecord[]

  createdAt                 DateTime                   @default(now()) @map("created_at")
  updatedAt                 DateTime                   @updatedAt @map("updated_at")
  reviewedTradeInRecords    ReviewedTradeInRecord[]
  humanReviewLearningEvents HumanReviewLearningEvent[]

  @@index([intakeBatchId])
  @@index([intakeItemId])
  @@index([status])
  @@index([workflowName])
  @@map("workflow_runs")
}

model WorkflowStep {
  id            String @id @default(cuid())
  workflowRunId String @map("workflow_run_id")

  stepName   String             @map("step_name")
  stepType   WorkflowStepType   @map("step_type")
  status     WorkflowStepStatus @default(PENDING)
  orderIndex Int                @map("order_index")

  inputJson  Json? @map("input_json")
  outputJson Json? @map("output_json")

  errorMessage String? @map("error_message")
  retryCount   Int     @default(0) @map("retry_count")

  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")

  workflowRun   WorkflowRun    @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)
  toolCallLogs  ToolCallLog[]
  modelCallLogs ModelCallLog[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([workflowRunId])
  @@index([status])
  @@index([stepType])
  @@map("workflow_steps")
}

model ToolCallLog {
  id             String  @id @default(cuid())
  workflowRunId  String? @map("workflow_run_id")
  workflowStepId String? @map("workflow_step_id")

  toolName String         @map("tool_name")
  status   ToolCallStatus @default(STARTED)

  inputJson  Json? @map("input_json")
  outputJson Json? @map("output_json")

  errorMessage String? @map("error_message")

  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")

  workflowRun  WorkflowRun?  @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)
  workflowStep WorkflowStep? @relation(fields: [workflowStepId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([workflowRunId])
  @@index([workflowStepId])
  @@index([toolName])
  @@index([status])
  @@map("tool_call_logs")
}

model ModelCallLog {
  id             String  @id @default(cuid())
  workflowRunId  String? @map("workflow_run_id")
  workflowStepId String? @map("workflow_step_id")

  provider ModelProviderName
  model    String
  status   ModelCallStatus   @default(STARTED)

  promptTokens     Int?   @map("prompt_tokens")
  completionTokens Int?   @map("completion_tokens")
  totalTokens      Int?   @map("total_tokens")
  latencyMs        Int?   @map("latency_ms")
  estimatedCostUsd Float? @map("estimated_cost_usd")

  requestJson  Json? @map("request_json")
  responseJson Json? @map("response_json")

  errorMessage String? @map("error_message")

  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")

  workflowRun  WorkflowRun?          @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)
  workflowStep WorkflowStep?         @relation(fields: [workflowStepId], references: [id], onDelete: SetNull)
  attemptLogs  ModelCallAttemptLog[]

  createdAt DateTime @default(now()) @map("created_at")

  @@index([workflowRunId])
  @@index([workflowStepId])
  @@index([provider])
  @@index([model])
  @@index([status])
  @@map("model_call_logs")
}

model ModelCallAttemptLog {
  id             String @id @default(cuid())
  modelCallLogId String @map("model_call_log_id")

  provider     ModelProviderName
  model        String
  attemptOrder Int                    @map("attempt_order")
  status       ModelCallAttemptStatus

  reason           String?
  errorMessage     String? @map("error_message")
  latencyMs        Int?    @map("latency_ms")
  estimatedCostUsd Float?  @map("estimated_cost_usd")

  modelCallLog ModelCallLog @relation(fields: [modelCallLogId], references: [id], onDelete: Cascade)

  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([modelCallLogId])
  @@index([provider])
  @@index([status])
  @@index([attemptOrder])
  @@map("model_call_attempt_logs")
}

model ReviewQueueItem {
  id            String  @id @default(cuid())
  intakeItemId  String? @map("intake_item_id")
  golfClubId    String? @map("golf_club_id")
  workflowRunId String? @map("workflow_run_id")

  reason ReviewReason
  status ReviewQueueStatus @default(OPEN)

  originalText         String? @map("original_text")
  proposedGolfClubJson Json?   @map("proposed_golf_club_json")

  reviewerNotes String?   @map("reviewer_notes")
  resolvedAt    DateTime? @map("resolved_at")

  intakeItem  IntakeItem?  @relation(fields: [intakeItemId], references: [id], onDelete: SetNull)
  golfClub    GolfClub?    @relation(fields: [golfClubId], references: [id], onDelete: SetNull)
  workflowRun WorkflowRun? @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)

  createdAt                 DateTime                   @default(now()) @map("created_at")
  updatedAt                 DateTime                   @updatedAt @map("updated_at")
  reviewedTradeInRecord     ReviewedTradeInRecord?
  humanReviewLearningEvents HumanReviewLearningEvent[]

  @@index([intakeItemId])
  @@index([golfClubId])
  @@index([workflowRunId])
  @@index([reason])
  @@index([status])
  @@map("review_queue_items")
}

model AiReadyIntakeRecord {
  id String @id @default(cuid())

  intakeBatchId String? @map("intake_batch_id")
  intakeItemId  String? @map("intake_item_id")
  workflowRunId String? @map("workflow_run_id")

  sourceRecordId String? @map("source_record_id")
  sourceType     String  @map("source_type")
  sourceName     String  @map("source_name")

  rawText     String @map("raw_text")
  cleanedText String @map("cleaned_text")

  normalizedJson     Json  @map("normalized_json")
  inferredSchemaJson Json? @map("inferred_schema_json")
  metadataJson       Json? @map("metadata_json")
  qualitySignalsJson Json? @map("quality_signals_json")

  status       AiReadyIntakeRecordStatus @default(READY_FOR_REVIEW)
  reviewNeeded Boolean                   @default(false) @map("review_needed")

  embeddingReady Boolean @default(false) @map("embedding_ready")
  ragReady       Boolean @default(false) @map("rag_ready")

  intakeBatch IntakeBatch? @relation(fields: [intakeBatchId], references: [id], onDelete: SetNull)
  intakeItem  IntakeItem?  @relation(fields: [intakeItemId], references: [id], onDelete: SetNull)
  workflowRun WorkflowRun? @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([intakeBatchId])
  @@index([intakeItemId])
  @@index([workflowRunId])
  @@index([sourceType])
  @@index([status])
  @@index([reviewNeeded])
  @@map("ai_ready_intake_records")
}

model KnowledgeDocument {
  id String @id @default(cuid())

  sourceType KnowledgeSourceType @map("source_type")
  title      String
  sourceName String              @map("source_name")

  rawText      String @map("raw_text")
  cleanedText  String @map("cleaned_text")
  metadataJson Json?  @map("metadata_json")

  chunks KnowledgeChunk[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([sourceType])
  @@index([sourceName])
  @@map("knowledge_documents")
}

model KnowledgeChunk {
  id         String @id @default(cuid())
  documentId String @map("document_id")

  chunkIndex Int                @map("chunk_index")
  chunkText  String             @map("chunk_text")
  chunkType  KnowledgeChunkType @map("chunk_type")

  brand       String?
  productLine String? @map("product_line")
  category    String?

  metadataJson  Json? @map("metadata_json")
  embeddingJson Json? @map("embedding_json")

  embedding          Unsupported("vector(64)")? @map("embedding")
  embeddingProvider  String?                    @map("embedding_provider")
  embeddingModel     String?                    @map("embedding_model")
  embeddingDimension Int?                       @map("embedding_dimension")
  embeddedAt         DateTime?                  @map("embedded_at")
  searchText         String                     @map("search_text")

  document KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([documentId, chunkIndex])
  @@index([documentId])
  @@index([chunkType])
  @@index([brand])
  @@index([productLine])
  @@index([category])
  @@map("knowledge_chunks")
}

model KnowledgeIngestionRun {
  id String @id @default(cuid())

  status     KnowledgeIngestionRunStatus @default(STARTED)
  sourceName String                      @map("source_name")

  documentsCreated Int     @default(0) @map("documents_created")
  chunksCreated    Int     @default(0) @map("chunks_created")
  errorMessage     String? @map("error_message")

  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  @@index([status])
  @@index([sourceName])
  @@map("knowledge_ingestion_runs")
}

model ReviewedTradeInRecord {
  id String @id @default(cuid())

  reviewQueueItemId String  @unique @map("review_queue_item_id")
  workflowRunId     String? @map("workflow_run_id")
  intakeItemId      String? @map("intake_item_id")

  originalText String? @map("original_text")

  correctedBrand          String? @map("corrected_brand")
  correctedProductLine    String? @map("corrected_product_line")
  correctedCategory       String? @map("corrected_category")
  correctedShaftFlex      String? @map("corrected_shaft_flex")
  correctedConditionGrade String? @map("corrected_condition_grade")
  conditionEvidenceText   String? @map("condition_evidence_text")
  correctedDemoValue      Int?    @map("corrected_demo_value")
  demoValuationNote       String? @map("demo_valuation_note")

  reviewerNotes String?  @map("reviewer_notes")
  approvedAt    DateTime @default(now()) @map("approved_at")

  reviewQueueItem ReviewQueueItem @relation(fields: [reviewQueueItemId], references: [id], onDelete: Cascade)
  workflowRun     WorkflowRun?    @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)
  intakeItem      IntakeItem?     @relation(fields: [intakeItemId], references: [id], onDelete: SetNull)

  learningEvents HumanReviewLearningEvent[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([workflowRunId])
  @@index([intakeItemId])
  @@index([correctedBrand])
  @@index([correctedCategory])
  @@index([correctedConditionGrade])
  @@map("reviewed_trade_in_records")
}

model HumanReviewLearningEvent {
  id String @id @default(cuid())

  reviewedTradeInRecordId String  @map("reviewed_trade_in_record_id")
  reviewQueueItemId       String  @map("review_queue_item_id")
  workflowRunId           String? @map("workflow_run_id")
  intakeItemId            String? @map("intake_item_id")

  fieldName        String  @map("field_name")
  rawTextMatch     String? @map("raw_text_match")
  proposedValue    String? @map("proposed_value")
  correctedValue   String? @map("corrected_value")
  evidenceText     String? @map("evidence_text")
  confidenceImpact String? @map("confidence_impact")
  reviewerNotes    String? @map("reviewer_notes")

  reviewedTradeInRecord ReviewedTradeInRecord @relation(fields: [reviewedTradeInRecordId], references: [id], onDelete: Cascade)
  reviewQueueItem       ReviewQueueItem       @relation(fields: [reviewQueueItemId], references: [id], onDelete: Cascade)
  workflowRun           WorkflowRun?          @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)
  intakeItem            IntakeItem?           @relation(fields: [intakeItemId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([reviewedTradeInRecordId])
  @@index([reviewQueueItemId])
  @@index([workflowRunId])
  @@index([intakeItemId])
  @@index([fieldName])
  @@index([rawTextMatch])
  @@map("human_review_learning_events")
}
