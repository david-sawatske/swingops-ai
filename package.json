{
  "name": "swingops-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Agentic golf retail workflow platform for intake, workflow orchestration, structured equipment records, review queues, and AI-ready operational logging.",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres"
  },
  "keywords": [
    "agentic-ai",
    "workflow-engine",
    "golf-retail",
    "fastify",
    "react",
    "typescript",
    "prisma",
    "postgresql"
  ],
  "author": "David Sawatske",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.7",
    "typescript": "^5.7.3"
  }
}
